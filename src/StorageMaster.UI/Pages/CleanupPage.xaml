<Page
    x:Class="StorageMaster.UI.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:StorageMaster.UI.Pages"
    xmlns:converters="using:StorageMaster.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis" />
        <converters:BoolToVisibilityConverter x:Key="InvBoolVis" Invert="True" />
        <converters:BoolNegationConverter     x:Key="NotBool" />
    </Page.Resources>

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="20" MaxWidth="960">

            <TextBlock Text="Cleanup" Style="{StaticResource TitleLargeTextBlockStyle}" />

            <!-- ── Session selector ────────────────────────────────────────── -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Select scan session" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ComboBox ItemsSource="{x:Bind ViewModel.RecentSessions}"
                              SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding RootPath}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding StartedUtc}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Analyse for Cleanup Opportunities"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.AnalyseCommand}"
                            IsEnabled="{x:Bind ViewModel.CanAnalyse, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- ── Cleanup Options (toggle cards per category) ─────────────── -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Cleanup Options" Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <!-- Deletion mode row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        <ToggleSwitch Grid.Column="0"
                                      Header="Send to Recycle Bin (recommended)"
                                      IsOn="{x:Bind ViewModel.UseRecycleBin, Mode=TwoWay}" />
                        <ToggleSwitch Grid.Column="1"
                                      Header="Clear entire Downloads folder (sub-option)"
                                      IsOn="{x:Bind ViewModel.ClearEntireDownloads, Mode=TwoWay}" />
                    </Grid>

                    <TextBlock Text="Categories to include:" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" />

                    <!-- Category toggle cards -->
                    <ListView ItemsSource="{x:Bind ViewModel.CategoryOptions}"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0,3" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:CleanupCategoryOption">
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="6" Padding="12,10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Description}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Opacity="0.65" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1"
                                                      IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0,0,0"
                                                      OnContent="" OffContent="" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Large-file / old-file sliders — visible only when that category is toggled on -->
                    <StackPanel Spacing="10"
                                Visibility="{x:Bind ViewModel.CategoryOptions[9].IsEnabled, Mode=OneWay, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.LargeFileSizeLabel, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>
                            <Slider Minimum="50" Maximum="5000" StepFrequency="50"
                                    Value="{x:Bind ViewModel.LargeFileSizeMb, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.OldFileAgeLabel, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>
                            <Slider Minimum="30" Maximum="3650" StepFrequency="30"
                                    Value="{x:Bind ViewModel.OldFileAgeDays, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status message -->
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}" Opacity="0.8"
                       Visibility="{x:Bind ViewModel.IsExecuting, Mode=OneWay, Converter={StaticResource InvBoolVis}}"/>

            <!-- Analysis loading spinner -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolVis}}"
                          Width="36" Height="36" HorizontalAlignment="Left" />

            <!-- Execution progress -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    Visibility="{x:Bind ViewModel.IsExecuting, Mode=OneWay, Converter={StaticResource BoolVis}}">
                <StackPanel Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.CleanupProgressText, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ProgressBar Value="{x:Bind ViewModel.CleanupProgressValue, Mode=OneWay}"
                                 Maximum="100" Height="8" />
                </StackPanel>
            </Border>

            <!-- Suggestions list -->
            <StackPanel Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolVis}}"
                        Spacing="12">

                <TextBlock Text="Suggestions" Style="{StaticResource SubtitleTextBlockStyle}" />

                <ListView ItemsSource="{x:Bind ViewModel.Suggestions}" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0,3" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:SuggestionItem">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8" Padding="16,12">
                                <Grid ColumnDefinitions="Auto,*,120,80,80">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{x:Bind Suggestion.Title}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Suggestion.Description}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Opacity="0.7" TextWrapping="Wrap" MaxLines="2"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{x:Bind SizeDisplay}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind CategoryDisplay}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <Border Grid.Column="4" CornerRadius="4" Padding="6,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind RiskDisplay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Execute bar -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Selected: "/>
                                <Run Text="{x:Bind ViewModel.TotalSelectedSize, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <CheckBox Content="Dry run (preview only)"
                                      IsChecked="{x:Bind ViewModel.IsDryRun, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Clean Up Selected…"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsExecuting, Mode=OneWay, Converter={StaticResource NotBool}}"
                                Click="ExecuteButton_Click"/>
                    </Grid>
                </Border>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
