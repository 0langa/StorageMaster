<Page
    x:Class="StorageMaster.UI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:StorageMaster.UI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:ByteSizeConverter x:Key="ByteSize" />
        <converters:BoolToVisibilityConverter x:Key="BoolVis" />
    </Page.Resources>

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="24" MaxWidth="900">

            <!-- Header -->
            <TextBlock Text="Dashboard" Style="{StaticResource TitleLargeTextBlockStyle}" />

            <!-- Status card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                Visibility="{x:Bind ViewModel.HasLastSession, Mode=OneWay, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Total scanned" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalScannedSize, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Files" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalFiles, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick actions -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Start New Scan"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.GoToScanCommand}" />
                <Button Content="View Last Results"
                        IsEnabled="{x:Bind ViewModel.HasLastSession, Mode=OneWay}"
                        Command="{x:Bind ViewModel.GoToResultsCommand}" />
            </StackPanel>

            <!-- Drive list -->
            <TextBlock Text="Drives" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Drives2, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8" Padding="16,12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock>
                                        <Run Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <Run Text=" " />
                                        <Run Text="{Binding VolumeLabel}" Opacity="0.7"/>
                                    </TextBlock>
                                    <ProgressBar Value="{Binding UsedBytes}"
                                                 Maximum="{Binding TotalBytes}"
                                                 Margin="0,8,0,4"
                                                 Height="6" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Right" FontWeight="SemiBold">
                                        <Run Text="{Binding FreeBytes, Converter={StaticResource ByteSize}}" />
                                        <Run Text=" free" />
                                    </TextBlock>
                                    <TextBlock Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}"
                                               HorizontalAlignment="Right">
                                        <Run Text="of " />
                                        <Run Text="{Binding TotalBytes, Converter={StaticResource ByteSize}}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
