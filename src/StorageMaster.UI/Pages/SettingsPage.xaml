<Page
    x:Class="StorageMaster.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:StorageMaster.UI.Converters"
    xmlns:local="using:StorageMaster.UI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis" />
    </Page.Resources>

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="24" MaxWidth="600">

            <TextBlock Text="Settings" Style="{StaticResource TitleLargeTextBlockStyle}" />

            <!-- Deletion behaviour -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Deletion Behaviour" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ToggleSwitch Header="Send to Recycle Bin (recommended)"
                                  IsOn="{x:Bind ViewModel.PreferRecycleBin, Mode=TwoWay}" />
                    <ToggleSwitch Header="Dry-run mode by default (preview without deleting)"
                                  IsOn="{x:Bind ViewModel.DryRunByDefault, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Large / old files thresholds -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Large &amp; Old File Thresholds" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.LargeFileThresholdLabel, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>
                        <Slider Minimum="50" Maximum="5000" StepFrequency="50"
                                Value="{x:Bind ViewModel.LargeFileSizeMb, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.OldFileAgeThresholdLabel, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>
                        <Slider Minimum="30" Maximum="3650" StepFrequency="30"
                                Value="{x:Bind ViewModel.OldFileAgeDays, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Scan options -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Text="Scan Options" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel>
                        <TextBlock Text="Default scan path" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>
                        <TextBox Text="{x:Bind ViewModel.DefaultScanPath, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.ScanParallelismLabel, Mode=OneWay}"
                                   Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>
                        <Slider Minimum="1" Maximum="16" StepFrequency="1"
                                Value="{x:Bind ViewModel.ScanParallelism, Mode=TwoWay}" />
                    </StackPanel>
                    <ToggleSwitch Header="Show hidden files in results"
                                  IsOn="{x:Bind ViewModel.ShowHiddenFiles, Mode=TwoWay}" />
                    <ToggleSwitch Header="Skip system folders"
                                  IsOn="{x:Bind ViewModel.SkipSystemFolders, Mode=TwoWay}" />
                    <ToggleSwitch Header="Use Turbo Scanner by default (Rust-powered parallel scanner)"
                                  IsOn="{x:Bind ViewModel.UseTurboScanner, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Excluded paths -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="Excluded Paths" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="These folders are skipped during every scan."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                    <ListView ItemsSource="{x:Bind ViewModel.ExcludedPaths}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1" Content="Remove"
                                            Tag="{x:Bind}"
                                            Click="RemovePath_Click"
                                            Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Content="Add Folder..." Click="AddExcludedFolder_Click"/>
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Save Settings"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.SaveCommand}" />
                <Button Content="Reset to Defaults"
                        Command="{x:Bind ViewModel.ResetToDefaultsCommand}" />
            </StackPanel>

            <!-- Feedback -->
            <TextBlock Text="{x:Bind ViewModel.SavedMessage, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                       Visibility="{x:Bind ViewModel.HasSavedMessage, Mode=OneWay, Converter={StaticResource BoolVis}}" />

            <!-- About -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="4">
                    <TextBlock Text="StorageMaster" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Version 1.4.1" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                    <TextBlock Text="Disk usage analyser and cleanup tool for Windows."
                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
